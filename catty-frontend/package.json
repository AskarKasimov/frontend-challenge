{
  "name": "catty-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "gen": "tsr generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check . && stylelint '**/*.{css,scss}'",
    "lint:fix": "biome check --write --no-errors-on-unmatched . && stylelint --fix '**/*.{css,scss}'",
    "lint:staged": "lint-staged --config .lintstagedrc.json",
    "lint:staged:fix": "lint-staged --config .lintstagedrc.fix.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "i18next": "^26.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tanstack/router-cli": "^1.166.25",
    "@tanstack/router-plugin": "^1.167.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.5",
    "lint-staged": "^16.4.0",
    "sass-embedded": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.4"
  }
}
